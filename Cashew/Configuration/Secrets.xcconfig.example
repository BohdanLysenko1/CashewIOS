// Secrets.xcconfig.example — Safe to commit
// Copy this file to Secrets.xcconfig and replace placeholder values.

// NOTE: xcconfig treats `//` as a comment — use `$()` between the slashes
//       so the URL expands correctly at build time.
SUPABASE_URL = https:/$()/YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY = your_anon_key_here
